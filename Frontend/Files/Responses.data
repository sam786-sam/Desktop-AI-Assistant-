**Python:**
```python
def rotate_array(arr, n):
    n = n % len(arr)
    return arr[-n:] + arr[:-n]
def print_array(arr):
    print(' '.join(map(str, arr)))
arr = [1, 2, 3, 4, 5]
n = 2
print("Original Array:")
print_array(arr)
rotated_arr = rotate_array(arr, n)
print("Rotated Array:")
print_array(rotated_arr)
```
**C++:**
```cpp
#include <iostream>
void rotate_array(int arr[], int n, int len) {
    int temp[len];
    // Copy the last 'n' elements to the beginning of the temporary array
    for (int i = 0; i < n; i++) {
        temp[i] = arr[len - n + i];
    }
    // Copy the remaining elements to the end of the temporary array
    for (int i = n; i < len; i++) {
        temp[i] = arr[i - n];
    }
    // Copy the rotated array back to the original array
    for (int i = 0; i < len; i++) {
        arr[i] = temp[i];
    }
}
void print_array(int arr[], int len) {
    for (int i = 0; i < len; i++) {
        std::cout << arr[i] << " ";
    }
    std::cout << std::endl;
}
int main() {
    int arr[] = {1, 2, 3, 4, 5};
    int n = 2;  // Number of positions to rotate
    int len = sizeof(arr) / sizeof(arr[0]);
    std::cout << "Original Array:" << std::endl;
    print_array(arr, len);
    rotate_array(arr, n, len);
    std::cout << "Rotated Array:" << std::endl;
    print_array(arr, len);
    return 0;
}
```
**JavaScript:**
```javascript
function rotateArray(arr, n) {
    n = n % arr.length;
    return arr.slice(-n).concat(arr.slice(0, -n));
}
function printArray(arr) {
    console.log(arr.join(' '));
}
let arr = [1, 2, 3, 4, 5];
let n = 2;
console.log("Original Array:");
printArray(arr);
let rotatedArr = rotateArray(arr, n);
console.log("Rotated Array:");
printArray(rotatedArr);
```
